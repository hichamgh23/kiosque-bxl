# Copier ce fichier en .env et remplir les valeurs

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplacer-par-une-vraie-cle-secrete

# False en production obligatoirement
DEBUG=False

# Votre domaine, ex: monsite.com,www.monsite.com
ALLOWED_HOSTS=monsite.com,www.monsite.com

# Telegram (optionnel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
